# Copy to .env and adjust. Dev defaults to SQLite; prod uses Postgres.
# SQLite (dev/tests, zero-config):
DATABASE_URL=sqlite:///./loaf_ledger.db
# Postgres (production), e.g.:
# DATABASE_URL=postgresql+psycopg://loaf:loaf@localhost:5432/loaf_ledger

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173

# Optional single-user app password (leave blank to disable auth entirely).
APP_PASSWORD=
